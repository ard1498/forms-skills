{
  "_template": "rule-with-comparison",
  "_description": "FUNCTION_CALL rule with a single IF condition (one field compared to a value or another field).",
  "_slots": {
    "EVENT_NAME":               "Human-readable label for the rule",
    "TRIGGER_FIELD_*":          "Trigger component fields — same as rule-no-condition template",
    "TRIGGER_EVENT":            "'is initialized' | 'is clicked' | 'is changed' | 'custom:eventName'",
    "CONDITION_FIELD_ID":       "Full dotted id of the field being tested, e.g. '$form.panel.accountType'",
    "CONDITION_FIELD_DISPLAY_NAME": "Display name of condition field, e.g. 'Account Type'",
    "CONDITION_FIELD_TYPE":     "Type string from transform-form output",
    "CONDITION_FIELD_DISPLAY_PATH": "Breadcrumb from transform-form, e.g. 'FORM/panel/'",
    "CONDITION_FIELD_NAME":     "Component name, e.g. 'accountType'",
    "CONDITION_FIELD_PARENT":   "Parent id, e.g. '$form.panel'",
    "OPERATOR":                 "One of: EQUALS_TO | NOT_EQUALS_TO | GREATER_THAN | LESS_THAN | GREATER_THAN_OR_EQUAL | LESS_THAN_OR_EQUAL | CONTAINS | DOES_NOT_CONTAIN | STARTS_WITH | ENDS_WITH | IS_EMPTY | IS_NOT_EMPTY | IS_TRUE | IS_FALSE | IS_VALID | IS_NOT_VALID",
    "RIGHT_OPERAND":            "OMIT entire third EXPRESSION item when operator is unary (IS_EMPTY, IS_NOT_EMPTY, IS_TRUE, IS_FALSE). For binary: STRING_LITERAL | NUMERIC_LITERAL | COMPONENT reference.",
    "FUNCTION_*":               "Function fields — same as rule-no-condition template"
  },
  "_notes": [
    "Unary operators (IS_EMPTY, IS_NOT_EMPTY, IS_TRUE, IS_FALSE) have NO right operand — remove the third EXPRESSION item from COMPARISON_EXPRESSION.items",
    "For binary operators (EQUALS_TO, GREATER_THAN, etc.) keep all three items in COMPARISON_EXPRESSION.items"
  ],
  "nodeName": "ROOT",
  "isValid": true,
  "enabled": true,
  "eventName": "{{EVENT_NAME}}",
  "items": [
    {
      "nodeName": "STATEMENT",
      "choice": {
        "nodeName": "TRIGGER_SCRIPTS",
        "items": [
          {
            "nodeName": "SINGLE_TRIGGER_SCRIPTS",
            "items": [
              {
                "nodeName": "COMPONENT",
                "value": {
                  "id": "{{TRIGGER_FIELD_ID}}",
                  "displayName": "{{TRIGGER_FIELD_DISPLAY_NAME}}",
                  "type": "{{TRIGGER_FIELD_TYPE}}",
                  "isDuplicate": false,
                  "displayPath": "{{TRIGGER_FIELD_DISPLAY_PATH}}",
                  "name": "{{TRIGGER_FIELD_NAME}}",
                  "parent": "{{TRIGGER_FIELD_PARENT}}"
                }
              },
              {
                "nodeName": "TRIGGER_EVENT",
                "value": "{{TRIGGER_EVENT}}"
              },
              {
                "nodeName": "When",
                "value": null
              },
              {
                "nodeName": "TRIGGER_EVENT_SCRIPTS",
                "items": [
                  {
                    "nodeName": "CONDITION",
                    "nested": false,
                    "choice": {
                      "nodeName": "COMPARISON_EXPRESSION",
                      "items": [
                        {
                          "nodeName": "EXPRESSION",
                          "choice": {
                            "nodeName": "COMPONENT",
                            "value": {
                              "id": "{{CONDITION_FIELD_ID}}",
                              "displayName": "{{CONDITION_FIELD_DISPLAY_NAME}}",
                              "type": "{{CONDITION_FIELD_TYPE}}",
                              "isDuplicate": false,
                              "displayPath": "{{CONDITION_FIELD_DISPLAY_PATH}}",
                              "name": "{{CONDITION_FIELD_NAME}}",
                              "parent": "{{CONDITION_FIELD_PARENT}}"
                            }
                          }
                        },
                        {
                          "nodeName": "OPERATOR",
                          "choice": {
                            "nodeName": "{{OPERATOR}}",
                            "value": null
                          }
                        },
                        {
                          "_note": "REMOVE this item entirely for unary operators (IS_EMPTY, IS_NOT_EMPTY, IS_TRUE, IS_FALSE)",
                          "nodeName": "EXPRESSION",
                          "choice": {
                            "_note": "Use STRING_LITERAL, NUMERIC_LITERAL, BOOLEAN_LITERAL, or COMPONENT",
                            "nodeName": "STRING_LITERAL",
                            "value": "{{RIGHT_VALUE}}"
                          }
                        }
                      ]
                    }
                  },
                  {
                    "nodeName": "Then",
                    "value": null
                  },
                  {
                    "nodeName": "BLOCK_STATEMENTS",
                    "items": [
                      {
                        "nodeName": "BLOCK_STATEMENT",
                        "choice": {
                          "nodeName": "FUNCTION_CALL",
                          "parentNodeName": "BLOCK_STATEMENT",
                          "functionName": {
                            "id": "{{FUNCTION_ID}}",
                            "displayName": "{{FUNCTION_DISPLAY_NAME}}",
                            "type": "STRING|NUMBER|BOOLEAN|DATE|ARRAY|OBJECT",
                            "isDuplicate": false,
                            "displayPath": "",
                            "args": [],
                            "impl": "$0()"
                          },
                          "params": []
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
}
