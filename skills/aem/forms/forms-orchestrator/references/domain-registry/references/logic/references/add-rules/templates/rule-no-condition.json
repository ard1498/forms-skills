{
  "_template": "rule-no-condition",
  "_description": "FUNCTION_CALL rule with no condition. Use when the function always runs on trigger.",
  "_slots": {
    "EVENT_NAME":               "Human-readable label for the rule, e.g. 'Handle Account Type Change'",
    "TRIGGER_FIELD_ID":         "Full dotted id, e.g. '$form.panel.fieldName' or '$form' for the form root",
    "TRIGGER_FIELD_DISPLAY_NAME": "Label shown in rule editor, e.g. 'Account Type'",
    "TRIGGER_FIELD_TYPE":       "Component type string from transform-form output, e.g. 'AFCOMPONENT|FIELD|DROPDOWN|STRING'",
    "TRIGGER_FIELD_DISPLAY_PATH": "Breadcrumb path from transform-form, e.g. 'FORM/panel/'",
    "TRIGGER_FIELD_NAME":       "Component name (last segment), e.g. 'accountType'",
    "TRIGGER_FIELD_PARENT":     "Parent id, e.g. '$form.panel' or '' for top-level",
    "TRIGGER_EVENT":            "'is initialized' | 'is clicked' | 'is changed' | 'custom:eventName'",
    "FUNCTION_ID":              "JS function name, e.g. 'handleAccountTypeChange'",
    "FUNCTION_DISPLAY_NAME":    "Human-readable function name, e.g. 'Handle Account Type Change'"
  },
  "nodeName": "ROOT",
  "isValid": true,
  "enabled": true,
  "eventName": "{{EVENT_NAME}}",
  "items": [
    {
      "nodeName": "STATEMENT",
      "choice": {
        "nodeName": "TRIGGER_SCRIPTS",
        "items": [
          {
            "nodeName": "SINGLE_TRIGGER_SCRIPTS",
            "items": [
              {
                "nodeName": "COMPONENT",
                "value": {
                  "id": "{{TRIGGER_FIELD_ID}}",
                  "displayName": "{{TRIGGER_FIELD_DISPLAY_NAME}}",
                  "type": "{{TRIGGER_FIELD_TYPE}}",
                  "isDuplicate": false,
                  "displayPath": "{{TRIGGER_FIELD_DISPLAY_PATH}}",
                  "name": "{{TRIGGER_FIELD_NAME}}",
                  "parent": "{{TRIGGER_FIELD_PARENT}}"
                }
              },
              {
                "nodeName": "TRIGGER_EVENT",
                "value": "{{TRIGGER_EVENT}}"
              },
              {
                "nodeName": "When",
                "value": null
              },
              {
                "nodeName": "TRIGGER_EVENT_SCRIPTS",
                "items": [
                  {
                    "nodeName": "CONDITION",
                    "nested": false,
                    "choice": null
                  },
                  {
                    "nodeName": "Then",
                    "value": null
                  },
                  {
                    "nodeName": "BLOCK_STATEMENTS",
                    "items": [
                      {
                        "nodeName": "BLOCK_STATEMENT",
                        "choice": {
                          "nodeName": "FUNCTION_CALL",
                          "parentNodeName": "BLOCK_STATEMENT",
                          "functionName": {
                            "id": "{{FUNCTION_ID}}",
                            "displayName": "{{FUNCTION_DISPLAY_NAME}}",
                            "type": "STRING|NUMBER|BOOLEAN|DATE|ARRAY|OBJECT",
                            "isDuplicate": false,
                            "displayPath": "",
                            "args": [],
                            "impl": "$0()"
                          },
                          "params": []
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
}
